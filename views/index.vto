<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ app.projectName }} - Redirect domains using only DNS</title>
  <meta name="description" content="Free DNS-based URL redirect service. Redirect any domain using a simple CNAME record — no server or hosting required." />
  <meta name="keywords" content="dns redirect, cname redirect, domain redirect, url redirect, free redirect service" />
  <meta name="author" content="Udlei Nati" />
  <meta property="og:title" content="{{ app.projectName }} - Redirect domains using only DNS" />
  <meta property="og:description" content="Free DNS-based URL redirect service. Redirect any domain using a simple CNAME record." />
  <meta property="og:type" content="website" />
  <link rel="icon" href="data:," />
  <script src="https://unpkg.com/base32.js@0.1.0/dist/base32.min.js"></script>
  <style>
    :root {
      --primary: #2563eb;
      --primary-dark: #1d4ed8;
      --bg: #f8fafc;
      --surface: #ffffff;
      --text: #1e293b;
      --text-secondary: #64748b;
      --border: #e2e8f0;
      --code-bg: #f1f5f9;
      --accent: #0ea5e9;
      --success: #10b981;
      --radius: 12px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    .container {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* Hero */
    .hero {
      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
      color: #fff;
      padding: 64px 0 56px;
      text-align: center;
    }

    .hero h1 {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      margin-bottom: 12px;
    }

    .hero p {
      font-size: 1.2rem;
      opacity: 0.92;
      max-width: 600px;
      margin: 0 auto 24px;
    }

    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 32px;
      margin-top: 28px;
      flex-wrap: wrap;
    }

    .hero-stats .stat {
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(8px);
      border-radius: 10px;
      padding: 14px 28px;
      text-align: center;
      min-width: 160px;
    }

    .hero-stats .stat-value {
      font-size: 1.6rem;
      font-weight: 700;
    }

    .hero-stats .stat-label {
      font-size: 0.85rem;
      opacity: 0.85;
    }

    /* How it works */
    .section {
      padding: 56px 0;
    }

    .section-title {
      font-size: 1.6rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 12px;
    }

    .section-subtitle {
      text-align: center;
      color: var(--text-secondary);
      max-width: 640px;
      margin: 0 auto 40px;
    }

    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 24px;
      margin-bottom: 0;
    }

    .step {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px 24px;
      text-align: center;
      transition: box-shadow 0.2s;
    }

    .step:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.06); }

    .step-icon {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .step h3 { font-size: 1.1rem; margin-bottom: 8px; }
    .step p { font-size: 0.92rem; color: var(--text-secondary); }

    /* Examples */
    .examples { background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

    .example-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 16px;
      overflow: hidden;
    }

    .example-header {
      padding: 16px 20px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 600;
      user-select: none;
      transition: background 0.15s;
    }

    .example-header:hover { background: var(--code-bg); }

    .example-header .arrow {
      transition: transform 0.2s;
      font-size: 0.75rem;
      color: var(--text-secondary);
      flex-shrink: 0;
    }

    .example-card.open .example-header .arrow { transform: rotate(90deg); }

    .example-header .example-summary {
      flex: 1;
      font-size: 0.95rem;
    }

    .example-header code {
      background: var(--code-bg);
      padding: 2px 7px;
      border-radius: 4px;
      font-size: 0.85rem;
      color: var(--primary);
    }

    .example-body {
      display: none;
      padding: 20px 24px;
      border-top: 1px solid var(--border);
      background: #fff;
    }

    .example-card.open .example-body { display: block; }

    .dns-record {
      background: var(--code-bg);
      border-radius: 8px;
      padding: 16px 20px;
      font-family: "SF Mono", "Fira Code", "Cascadia Code", monospace;
      font-size: 0.85rem;
      margin: 12px 0;
      overflow-x: auto;
    }

    .dns-record .row {
      display: flex;
      gap: 16px;
      padding: 4px 0;
      flex-wrap: wrap;
    }

    .dns-record .label {
      color: var(--text-secondary);
      min-width: 100px;
    }

    .dns-record .value { font-weight: 600; color: var(--text); }

    .tip {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      margin-top: 12px;
      padding: 10px 14px;
      background: #eff6ff;
      border-radius: 8px;
      font-size: 0.88rem;
      color: var(--primary-dark);
    }

    .tip-icon { flex-shrink: 0; font-size: 1rem; }

    /* Converter */
    .converter {
      background: var(--surface);
    }

    .converter-box {
      max-width: 640px;
      margin: 0 auto;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px;
    }

    .converter-box label {
      display: block;
      font-weight: 600;
      font-size: 0.9rem;
      margin-bottom: 6px;
      color: var(--text);
    }

    .converter-box input {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.95rem;
      font-family: inherit;
      outline: none;
      transition: border 0.2s;
    }

    .converter-box input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }

    .input-group {
      position: relative;
      margin-top: 16px;
    }

    .input-group input { padding-right: 80px; }

    .btn-copy {
      position: absolute;
      right: 4px;
      top: 50%;
      transform: translateY(-50%);
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 8px 16px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }

    .btn-copy:hover { background: var(--primary-dark); }
    .btn-copy.copied { background: var(--success); }

    .converter-arrow {
      text-align: center;
      padding: 12px 0;
      color: var(--text-secondary);
      font-size: 1.3rem;
    }

    /* Parameters ref */
    .params-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 16px;
      font-size: 0.9rem;
    }

    .params-table th {
      text-align: left;
      padding: 10px 14px;
      background: var(--code-bg);
      font-weight: 600;
      border-bottom: 2px solid var(--border);
    }

    .params-table td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }

    .params-table code {
      background: var(--code-bg);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.82rem;
      white-space: nowrap;
    }

    /* Footer */
    footer {
      background: var(--text);
      color: #cbd5e1;
      padding: 48px 0 32px;
    }

    footer a { color: var(--accent); text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    .footer-main {
      display: flex;
      justify-content: space-between;
      gap: 32px;
      flex-wrap: wrap;
      margin-bottom: 32px;
    }

    .footer-col { flex: 1; min-width: 200px; }
    .footer-col h4 { color: #fff; margin-bottom: 12px; font-size: 1rem; }
    .footer-col p, .footer-col li { font-size: 0.88rem; line-height: 1.7; }
    .footer-col ul { list-style: none; }

    .footer-seo {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 24px;
    }

    .footer-seo-block {
      margin-bottom: 16px;
    }

    .footer-seo-block h5 {
      color: #94a3b8;
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
    }

    .footer-seo-block p {
      font-size: 0.78rem;
      color: #64748b;
      line-height: 1.6;
    }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 20px;
      margin-top: 20px;
      text-align: center;
      font-size: 0.82rem;
      color: #64748b;
    }

    @media (max-width: 640px) {
      .hero h1 { font-size: 1.8rem; }
      .hero p { font-size: 1rem; }
      .hero-stats { gap: 12px; }
      .hero-stats .stat { min-width: 130px; padding: 10px 16px; }
      .converter-box { padding: 20px; }
      .dns-record .row { flex-direction: column; gap: 2px; }
    }
  </style>
</head>

<body>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>{{ app.projectName }}</h1>
      <p>Redirect any domain using only a DNS record. No server, no hosting, no code — just a simple CNAME.</p>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-value">{{ statistics.periodDomains }}</div>
          <div class="stat-label">domains in last 24h</div>
        </div>
        <div class="stat">
          <div class="stat-value">{{ statistics.everDomains }}</div>
          <div class="stat-label">total domains served</div>
        </div>
        <div class="stat">
          <div class="stat-value" id="uptime">...</div>
          <div class="stat-label">uptime</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">How it works</h2>
      <p class="section-subtitle">Three simple steps. No account required, no sign-up, completely free and open source.</p>
      <div class="steps">
        <div class="step">
          <div class="step-icon">1</div>
          <h3>Point your domain</h3>
          <p>Create an <strong>A record</strong> pointing your domain to our server IP: <code>{{ app.entryIp }}</code></p>
        </div>
        <div class="step">
          <div class="step-icon">2</div>
          <h3>Set the destination</h3>
          <p>Create a <strong>CNAME record</strong> encoding the destination, e.g. <code>destination.com.{{ app.fqdn }}</code></p>
        </div>
        <div class="step">
          <div class="step-icon">3</div>
          <h3>Done!</h3>
          <p>Visitors are automatically redirected with a <strong>301 redirect</strong>. That's it — it just works.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Examples -->
  <section class="section examples">
    <div class="container">
      <h2 class="section-title">Examples</h2>
      <p class="section-subtitle">Click each example to see the exact DNS records you need to configure.</p>

      <!-- Example 1 -->
      <div class="example-card open">
        <div class="example-header" onclick="toggleExample(this)">
          <span class="arrow">&#9654;</span>
          <span class="example-summary">
            Redirect <code>my-domain.com</code> &rarr; <code>www.my-domain.com</code>
          </span>
        </div>
        <div class="example-body">
          <p>Redirect your bare/root domain to the www version:</p>
          <div class="dns-record">
            <div class="row">
              <span class="label">Host:</span>
              <span class="value">&lt;empty&gt; (or @)</span>
              <span class="label">Type:</span>
              <span class="value">A</span>
              <span class="label">Value:</span>
              <span class="value">{{ app.entryIp }}</span>
            </div>
            <div class="row">
              <span class="label">Host:</span>
              <span class="value">redirect</span>
              <span class="label">Type:</span>
              <span class="value">CNAME</span>
              <span class="label">Value:</span>
              <span class="value">www.my-domain.com.{{ app.fqdn }}</span>
            </div>
          </div>
          <div class="tip">
            <span class="tip-icon">💡</span>
            <span>Add <code>.opts-https</code> to force HTTPS: <code>www.my-domain.com.opts-https.{{ app.fqdn }}</code></span>
          </div>
        </div>
      </div>

      <!-- Example 2 -->
      <div class="example-card">
        <div class="example-header" onclick="toggleExample(this)">
          <span class="arrow">&#9654;</span>
          <span class="example-summary">
            Redirect <code>www.my-domain.com</code> &rarr; <code>www.other-domain.com</code>
          </span>
        </div>
        <div class="example-body">
          <p>Redirect a subdomain to a completely different domain:</p>
          <div class="dns-record">
            <div class="row">
              <span class="label">Host:</span>
              <span class="value">www</span>
              <span class="label">Type:</span>
              <span class="value">CNAME</span>
              <span class="label">Value:</span>
              <span class="value">www.other-domain.com.{{ app.fqdn }}</span>
            </div>
          </div>
          <div class="tip">
            <span class="tip-icon">💡</span>
            <span>Only one DNS record needed for subdomain redirects!</span>
          </div>
        </div>
      </div>

      <!-- Example 3 -->
      <div class="example-card">
        <div class="example-header" onclick="toggleExample(this)">
          <span class="arrow">&#9654;</span>
          <span class="example-summary">
            Redirect preserving the path: <code>/page</code> &rarr; <code>/page</code>
          </span>
        </div>
        <div class="example-body">
          <p>Keep the original URL path and query string when redirecting:</p>
          <div class="dns-record">
            <div class="row">
              <span class="label">Host:</span>
              <span class="value">www</span>
              <span class="label">Type:</span>
              <span class="value">CNAME</span>
              <span class="label">Value:</span>
              <span class="value">www.other-domain.com.opts-uri.{{ app.fqdn }}</span>
            </div>
          </div>
          <div class="tip">
            <span class="tip-icon">💡</span>
            <span>The <code>.opts-uri</code> parameter passes the full request path and query string to the destination.</span>
          </div>
        </div>
      </div>

      <!-- Example 4 -->
      <div class="example-card">
        <div class="example-header" onclick="toggleExample(this)">
          <span class="arrow">&#9654;</span>
          <span class="example-summary">
            Redirect with path &amp; query: <code>jobs.my-domain.com</code> &rarr; <code>my-domain.com/careers?ref=dns</code>
          </span>
        </div>
        <div class="example-body">
          <p>Redirect a subdomain to a specific path with query parameters:</p>
          <div class="dns-record">
            <div class="row">
              <span class="label">Host:</span>
              <span class="value">jobs</span>
              <span class="label">Type:</span>
              <span class="value">CNAME</span>
              <span class="label">Value:</span>
              <span class="value">my-domain.com.opts-slash.careers.opts-query-onswg5lsnf2a.{{ app.fqdn }}</span>
            </div>
          </div>
          <div class="tip">
            <span class="tip-icon">💡</span>
            <span><code>.opts-slash.careers</code> adds the path <code>/careers</code>. The query <code>ref=dns</code> is Base32-encoded as <code>onswg5lsnf2a</code>. Use the converter below to generate these values automatically.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CNAME Converter -->
  <section class="section converter">
    <div class="container">
      <h2 class="section-title">CNAME Generator</h2>
      <p class="section-subtitle">Paste your destination URL and get the CNAME value ready to use.</p>
      <div class="converter-box">
        <label for="url">Destination URL</label>
        <input type="url" id="url" placeholder="https://www.example.com/path?query=value" autocomplete="off" />
        <div class="converter-arrow">&#8595;</div>
        <label for="cname">CNAME value</label>
        <div class="input-group">
          <input type="text" id="cname" readonly placeholder="Generated CNAME will appear here..." />
          <button class="btn-copy" id="copyCNAME" type="button">Copy</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Parameters Reference -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Parameters Reference</h2>
      <p class="section-subtitle">Modifiers you can add to your CNAME record to customize the redirect behavior.</p>
      <table class="params-table">
        <thead>
          <tr>
            <th>Parameter</th>
            <th>Description</th>
            <th>Example</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>.opts-https</code></td>
            <td>Force redirect to HTTPS</td>
            <td><code>example.com.opts-https.{{ app.fqdn }}</code></td>
          </tr>
          <tr>
            <td><code>.opts-uri</code></td>
            <td>Preserve original path and query string</td>
            <td><code>example.com.opts-uri.{{ app.fqdn }}</code></td>
          </tr>
          <tr>
            <td><code>.opts-slash.{path}</code></td>
            <td>Append a path to the destination URL</td>
            <td><code>example.com.opts-slash.blog.{{ app.fqdn }}</code></td>
          </tr>
          <tr>
            <td><code>.opts-path-{base32}</code></td>
            <td>Base32-encoded path (for special characters)</td>
            <td><code>example.com.opts-path-mfrgg.{{ app.fqdn }}</code></td>
          </tr>
          <tr>
            <td><code>.opts-query-{base32}</code></td>
            <td>Base32-encoded query string</td>
            <td><code>example.com.opts-query-nfxgg.{{ app.fqdn }}</code></td>
          </tr>
          <tr>
            <td><code>.opts-statuscode-{code}</code></td>
            <td>HTTP status code: 301, 302, 307 or 308</td>
            <td><code>example.com.opts-statuscode-302.{{ app.fqdn }}</code></td>
          </tr>
          <tr>
            <td><code>.opts-port-{port}</code></td>
            <td>Redirect to a specific port</td>
            <td><code>example.com.opts-port-8080.{{ app.fqdn }}</code></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container">
      <div class="footer-main">
        <div class="footer-col">
          <h4>{{ app.projectName }}</h4>
          <p>Free, open-source DNS redirect service. No sign-up, no tracking, no limits.</p>
          <p style="margin-top: 12px;">
            <a href="https://github.com/udleinati/redirect.center">GitHub</a> &middot;
            <a href="https://github.com/udleinati/redirect.center/issues">Issues</a> &middot;
            <a href="mailto:udlei@nati.biz">Contact</a>
          </p>
        </div>
        <div class="footer-col">
          <h4>Quick Setup</h4>
          <ul>
            <li>1. A record &rarr; <code style="color:#94a3b8">{{ app.entryIp }}</code></li>
            <li>2. CNAME &rarr; <code style="color:#94a3b8">dest.{{ app.fqdn }}</code></li>
            <li>3. Wait for DNS propagation</li>
          </ul>
        </div>
      </div>

      <!-- SEO multilingual blocks -->
      <div class="footer-seo">
        <div class="footer-seo-block">
          <h5>English</h5>
          <p>redirect.center is a free DNS-based domain redirect service. Redirect URLs, domains, and subdomains using only CNAME records. No server configuration needed — just point your DNS and go. Supports HTTP 301, 302, 307, 308 redirects, path forwarding, query strings, HTTPS, and custom ports.</p>
        </div>
        <div class="footer-seo-block">
          <h5>Português</h5>
          <p>redirect.center é um serviço gratuito de redirecionamento de domínios via DNS. Redirecione URLs, domínios e subdomínios usando apenas registros CNAME. Sem necessidade de configurar servidor — basta apontar seu DNS. Suporta redirecionamentos HTTP 301, 302, 307, 308, encaminhamento de caminho, query strings, HTTPS e portas personalizadas. Redirecionar por DNS, redirecionamento de domínio, redirecionar CNAME DNS.</p>
        </div>
        <div class="footer-seo-block">
          <h5>Español</h5>
          <p>redirect.center es un servicio gratuito de redirección de dominios basado en DNS. Redirija URLs, dominios y subdominios usando solo registros CNAME. Sin necesidad de configurar un servidor — solo apunte su DNS. Soporta redirecciones HTTP 301, 302, 307, 308, reenvío de rutas, cadenas de consulta, HTTPS y puertos personalizados. Redirigir mediante DNS, redireccionamiento de dominio, DNS CNAME redirección.</p>
        </div>
        <div class="footer-seo-block">
          <h5>Deutsch</h5>
          <p>redirect.center ist ein kostenloser DNS-basierter Domain-Weiterleitungsdienst. Leiten Sie URLs, Domains und Subdomains nur mit CNAME-Einträgen um. Keine Serverkonfiguration erforderlich — einfach DNS einstellen und fertig. Unterstützt HTTP 301, 302, 307, 308 Weiterleitungen, Pfadweiterleitung, Query-Strings, HTTPS und benutzerdefinierte Ports.</p>
        </div>
        <div class="footer-seo-block">
          <h5>Français</h5>
          <p>redirect.center est un service gratuit de redirection de domaines basé sur le DNS. Redirigez des URL, domaines et sous-domaines en utilisant uniquement des enregistrements CNAME. Aucune configuration de serveur requise — pointez simplement votre DNS. Prend en charge les redirections HTTP 301, 302, 307, 308, le transfert de chemin, les chaînes de requête, HTTPS et les ports personnalisés.</p>
        </div>
        <div class="footer-seo-block">
          <h5>Italiano</h5>
          <p>redirect.center è un servizio gratuito di reindirizzamento domini basato su DNS. Reindirizza URL, domini e sottodomini usando solo record CNAME. Nessuna configurazione del server richiesta — basta puntare il DNS. Supporta reindirizzamenti HTTP 301, 302, 307, 308, inoltro del percorso, stringhe di query, HTTPS e porte personalizzate.</p>
        </div>
        <div class="footer-seo-block">
          <h5>日本語</h5>
          <p>redirect.centerは、DNSベースの無料ドメインリダイレクトサービスです。CNAMEレコードのみを使用して、URL、ドメイン、サブドメインをリダイレクトできます。サーバー設定は不要です。HTTP 301、302、307、308リダイレクト、パス転送、クエリ文字列、HTTPS、カスタムポートをサポートしています。</p>
        </div>
        <div class="footer-seo-block">
          <h5>Русский</h5>
          <p>redirect.center — бесплатный сервис перенаправления доменов на основе DNS. Перенаправляйте URL-адреса, домены и поддомены, используя только записи CNAME. Настройка сервера не требуется — просто укажите DNS. Поддерживает перенаправления HTTP 301, 302, 307, 308, пересылку пути, строки запросов, HTTPS и пользовательские порты.</p>
        </div>
        <div class="footer-seo-block">
          <h5>한국어</h5>
          <p>redirect.center는 DNS 기반의 무료 도메인 리디렉션 서비스입니다. CNAME 레코드만으로 URL, 도메인, 서브도메인을 리디렉션할 수 있습니다. 서버 설정이 필요 없습니다. HTTP 301, 302, 307, 308 리디렉션, 경로 전달, 쿼리 문자열, HTTPS 및 사용자 지정 포트를 지원합니다.</p>
        </div>
        <div class="footer-seo-block">
          <h5>中文</h5>
          <p>redirect.center 是一个基于 DNS 的免费域名重定向服务。仅使用 CNAME 记录即可重定向 URL、域名和子域名。无需服务器配置，只需设置 DNS 即可。支持 HTTP 301、302、307、308 重定向、路径转发、查询字符串、HTTPS 和自定义端口。</p>
        </div>
        <div class="footer-seo-block">
          <h5>العربية</h5>
          <p>redirect.center هو خدمة مجانية لإعادة توجيه النطاقات عبر DNS. قم بإعادة توجيه عناوين URL والنطاقات والنطاقات الفرعية باستخدام سجلات CNAME فقط. لا حاجة لتكوين خادم. يدعم عمليات إعادة التوجيه HTTP 301 و302 و307 و308 وإعادة توجيه المسار وسلاسل الاستعلام وHTTPS والمنافذ المخصصة.</p>
        </div>
        <div class="footer-seo-block">
          <h5>हिन्दी</h5>
          <p>redirect.center एक मुफ्त DNS-आधारित डोमेन रीडायरेक्ट सेवा है। केवल CNAME रिकॉर्ड का उपयोग करके URL, डोमेन और सबडोमेन को रीडायरेक्ट करें। सर्वर कॉन्फ़िगरेशन की आवश्यकता नहीं है। HTTP 301, 302, 307, 308 रीडायरेक्ट, पथ अग्रेषण, क्वेरी स्ट्रिंग, HTTPS और कस्टम पोर्ट का समर्थन करता है।</p>
        </div>
      </div>

      <div class="footer-bottom">
        &copy; {{ app.projectName }} &middot; Open source under MIT License &middot;
        <a href="https://github.com/udleinati/redirect.center">GitHub</a>
      </div>
    </div>
  </footer>

  <script>
    // Accordion
    function toggleExample(header) {
      const card = header.parentElement;
      card.classList.toggle('open');
    }

    // Uptime
    let upSeconds = {{ uptime }};

    function formatUptime(s) {
      const d = Math.floor(s / 86400);
      const h = Math.floor(s / 3600 % 24);
      const m = Math.floor(s / 60 % 60);
      const sec = Math.floor(s % 60);
      const parts = [];
      if (d > 0) parts.push(d + 'd');
      if (h > 0) parts.push(h + 'h');
      if (m > 0) parts.push(m + 'm');
      parts.push(sec + 's');
      return parts.join(' ');
    }

    function updateUptime() {
      document.getElementById('uptime').textContent = formatUptime(upSeconds++);
      setTimeout(updateUptime, 1000);
    }
    updateUptime();

    // CNAME converter
    document.addEventListener('DOMContentLoaded', function () {
      const urlInput = document.getElementById('url');
      const cnameOutput = document.getElementById('cname');
      const copyBtn = document.getElementById('copyCNAME');

      urlInput.addEventListener('input', function () {
        cnameOutput.value = transformURLtoCNAME(this.value);
      });

      copyBtn.addEventListener('click', function () {
        if (!cnameOutput.value) return;
        navigator.clipboard.writeText(cnameOutput.value).then(() => {
          copyBtn.textContent = 'Copied!';
          copyBtn.classList.add('copied');
          setTimeout(() => {
            copyBtn.textContent = 'Copy';
            copyBtn.classList.remove('copied');
          }, 2000);
        });
      });

      function transformURLtoCNAME(urlStr) {
        if (!urlStr) return '';
        let url;
        try { url = new URL(urlStr); } catch { return ''; }

        let result = url.hostname;

        // path with special characters → base32 encode
        if (url.pathname && url.pathname !== '/') {
          if (!url.pathname.match(/^[\/a-z0-9\-_\.]+$/) || url.pathname.match(/query/)) {
            result += '.opts-path-' + base32.encode(
              new TextEncoder().encode(url.pathname),
              { type: 'rfc4648', lc: true }
            );
          } else {
            // path without special characters → opts-slash
            result += url.pathname
              .replace(/\//g, '.opts-slash.')
              .replace(/([^.])$/, '$1')
              .replace(/\.$/, '');
          }
        }

        // query string → base32 encode
        if (url.search) {
          result += '.opts-query-' + base32.encode(
            new TextEncoder().encode(url.search.slice(1)),
            { type: 'rfc4648', lc: true }
          );
        }

        // https
        if (url.protocol === 'https:') {
          result += '.opts-https';
        }

        result += '.{{ app.fqdn }}.';
        return result;
      }
    });
  </script>
</body>

</html>
