# =============================================================================
# redirect.center — Production Environment Variables
# Copy to .env and fill in the values
# =============================================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=          # REQUIRED: strong password for the database
# POSTGRES_DB=redirect_center
# POSTGRES_USER=redirect_center

# --- Domain / Network ---
FQDN=redirect.center
ENTRY_IP=                   # REQUIRED: public IP of this server (the IP users set in their A record)
# BASE_URL=https://redirect.center

# --- SMTP (for magic links and notifications) ---
SMTP_HOST=                  # REQUIRED: e.g. smtp.gmail.com, email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@redirect.center

# --- Stripe (for Pro subscriptions) ---
STRIPE_SECRET_KEY=          # REQUIRED: sk_live_...
STRIPE_PUBLISHABLE_KEY=     # REQUIRED: pk_live_...
STRIPE_WEBHOOK_SECRET=      # REQUIRED: whsec_... (from Stripe Dashboard → Webhooks)
STRIPE_PRICE_SIMPLE_MONTHLY=
STRIPE_PRICE_SIMPLE_YEARLY=
STRIPE_PRICE_WILDCARD_MONTHLY=
STRIPE_PRICE_WILDCARD_YEARLY=

# --- Certificates (ACME / Let's Encrypt) ---
CERT_ENCRYPTION_KEY=        # REQUIRED: 64 hex chars (openssl rand -hex 32)
# ACME_DIRECTORY_URL=https://acme-v02.api.letsencrypt.org/directory
# DNS_PROVIDER=cloudflare

# --- Sandbox mode ---
# SANDBOX=true              # Set to "true" to show sandbox banner (test environment)

# --- Tuning (optional) ---
# LOGGER_LEVEL=info
# SESSION_DURATION_HOURS=24
# MAGIC_LINK_DURATION_HOURS=1
# VALIDATION_WORKER_INTERVAL_SECONDS=60
# RENEWAL_WORKER_INTERVAL_SECONDS=3600
# NOTIFICATION_WORKER_INTERVAL_SECONDS=3600
# SYNC_INTERVAL_SECONDS=30
